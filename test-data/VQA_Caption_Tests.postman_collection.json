{
	"info": {
		"_postman_id": "vqa-test-medical",
		"name": "VQA & Caption - Kiểm thử Y tế",
		"description": "Collection test API VQA và Caption cho đề tài Phát hiện và phân vùng tổn thương y tế - Thành viên 5\n\nAPI trực tiếp (Colab + ngrok): dùng /vqa và /caption\nAPI qua Backend Node.js: dùng /api/vqa và /api/caption",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://tile-clover-apple.ngrok-free.dev",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health - Kiểm tra API",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "ngrok-skip-browser-warning",
								"value": "true",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					}
				}
			]
		},
		{
			"name": "VQA - X-quang",
